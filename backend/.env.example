# Port selection
PORT=5000

# Database Configuration (PostgreSQL connection string)
# If DATABASE_URL is set, it overrides the individual DB_ properties below.
DATABASE_URL=postgres://postgres:009900@localhost:5432/smart_delivery


# Detailed Database properties (fallback if DATABASE_URL is empty)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=009900
DB_NAME=smart_delivery
DB_SSL=false

# Authentication Configurations
# Secure JWT secret key for signing user sessions
JWT_SECRET=replace_with_your_super_secret_jwt_key_here

# Nodemailer Email configurations (e.g., Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM="Smart Delivery <noreply@smartdelivery.app>"
